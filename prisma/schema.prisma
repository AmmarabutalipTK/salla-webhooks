generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id               Int       @id @default(autoincrement())
  phone            String    @unique

  defaultAddressId Int?

  addresses        Address[]
}

model Address {
  id         Int      @id @default(autoincrement())

  customerId Int
   courierId  Int?
  customer   Customer @relation(fields: [customerId], references: [id])

  name       String
  city       String?
  district   String?
  street     String?
  latitude   Float?
  longitude  Float?
}